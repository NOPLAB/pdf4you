# ==== プラットフォーム ====
# Slack（未設定なら Slack アダプタは起動しない）
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=                 # Socket Mode 用（xapp-...）
SLACK_WATCH_CHANNELS=            # 監視するチャンネルID（カンマ区切り, 空なら全チャンネル）

# Discord（未設定なら Discord アダプタは起動しない）
DISCORD_BOT_TOKEN=
DISCORD_WATCH_CHANNELS=          # 監視するチャンネルID（カンマ区切り, 空なら全チャンネル）

# ==== アクセス制御（未設定なら誰でも可 / 設定するとそのユーザーのみ）====
SLACK_ALLOWED_USERS=             # SlackユーザーID（カンマ区切り）
DISCORD_ALLOWED_USERS=           # DiscordユーザーID（カンマ区切り）

# ==== 翻訳（pdf2zh-next / OpenAI互換）====
TRANSLATE_BASE_URL=http://localhost:8000/v1     # 例: vLLM
TRANSLATE_API_KEY=dummy
TRANSLATE_MODEL=
LANG_IN=auto
LANG_OUT=ja

# ==== 要約（OpenAI互換 / 翻訳とは別モデル可）====
SUMMARY_BASE_URL=http://localhost:11434/v1      # 例: Ollama
SUMMARY_API_KEY=dummy
SUMMARY_MODEL=

# ==== 動作 ====
MAX_CONCURRENCY=1                # 同時に処理するジョブ数
MAX_PDF_MB=50                    # 受け付けるPDFの最大サイズ(MB)
FILE_RETENTION_DAYS=7            # 生成物の保持日数
WORK_DIR=./work                  # 一時ファイル・生成物の作業ディレクトリ
LOG_LEVEL=INFO
